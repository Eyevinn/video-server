{
  "name": "open-video-server",
  "version": "1.0.0",
  "description": "A powerful, open-source video streaming server built with Node.js and FFmpeg. Supports UDP, SRT, RTMP streaming with live thumbnails and automatic recovery.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": [
    "video",
    "streaming",
    "ffmpeg",
    "udp",
    "srt",
    "rtmp",
    "thumbnails",
    "open-source",
    "nodejs",
    "broadcast",
    "live-streaming",
    "video-server"
  ],
  "author": "Open Video Server Contributors",
  "license": "Apache-2.0",
  "homepage": "https://github.com/your-org/open-video-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/open-video-server.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/open-video-server/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.5.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1"
  }
}
